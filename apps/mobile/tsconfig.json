{
  "extends": "expo/tsconfig.base",
  "compilerOptions": {
    "strict": true,
    "skipLibCheck": true,
    "baseUrl": ".",
    "paths": {
      "@/*": ["./*"],
      "@vak/ui": ["../../packages/ui/src/index.ts"],
      "@vak/contract": ["../../packages/contract/src/index.ts"]
    }
  },
  "include": [
    "src/**/*.ts",
    "src/**/*.tsx",
    "src/declarations/**/*.d.ts",
    "nativewind-env.d.ts"
  ]
}